{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PuppetFlow Playground",
  "version": "0.1.0",
  "identifier": "dev.puppetflow.playground",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PuppetFlow Playground",
        "width": 720,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
