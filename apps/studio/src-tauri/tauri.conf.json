{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PuppetFlow Studio",
  "version": "0.1.0",
  "identifier": "dev.puppetflow.studio",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PuppetFlow Studio",
        "width": 1100,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
