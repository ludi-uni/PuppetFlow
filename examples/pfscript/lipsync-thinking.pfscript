-- 興味に応じて笑顔（単体 .pfscript 用。公式 .pfpreset では Graph が mouthX を担当）

smile =
    interest * 0.4

-- 音量で口パク

mouthY =
    volume

-- 軽いゆらぎ

headTilt =
    noise(time * 0.2) * 0.1

-- 考え込み状態

if interest > 0.7 then

    thinking(
        intensity = 0.8
    )

end

-- 音素リップシンク

if currentPhoneme == "A" then
    MouthA = 1
end

if currentPhoneme == "I" then
    MouthI = 1
end
