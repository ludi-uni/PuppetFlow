{
  "name": "@puppetflow/behavior-packs",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./presets/*": "./presets/*"
  },
  "files": [
    "dist",
    "presets"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
