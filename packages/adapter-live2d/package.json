{
  "name": "@puppetflow/adapter-live2d",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mappings/default.json": "@puppetflow/motion-mapper/profiles/live2d.json"
  },
  "files": [
    "dist",
    "mappings"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@puppetflow/adapter-core": "workspace:*",
    "@puppetflow/adapter-vmc": "workspace:*",
    "@puppetflow/core": "workspace:*",
    "@puppetflow/motion-mapper": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
