{
  "name": "@puppetflow/extension-bundled",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --dir ."
  },
  "dependencies": {
    "@puppetflow/core": "workspace:*",
    "@puppetflow/extension-core": "workspace:*",
    "@puppetflow/plugin-animal-ears": "workspace:*",
    "@puppetflow/plugin-lookaround": "workspace:*",
    "@puppetflow/plugin-tail": "workspace:*",
    "@puppetflow/plugin-thinking": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
