{
  "name": "@puppetflow/preset",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/read-pfscript-file.d.ts",
      "import": "./dist/read-pfscript-file.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/read-pfscript-file.ts --format esm --dts --clean",
    "test": "vitest run --dir ."
  },
  "dependencies": {
    "@puppetflow/behavior": "workspace:*",
    "@puppetflow/core": "workspace:*",
    "@puppetflow/extension-core": "workspace:*",
    "@puppetflow/motion-graph": "workspace:*",
    "@puppetflow/pfscript-core": "workspace:*",
    "@puppetflow/plugin-attention": "workspace:*",
    "@puppetflow/plugin-blink": "workspace:*",
    "@puppetflow/plugin-emotion": "workspace:*",
    "@puppetflow/plugin-gaze": "workspace:*",
    "@puppetflow/plugin-idle": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
